# Database
DATABASE_URL=postgres://dev:dev@db:5432/tokobangunan?sslmode=disable

# Application
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug
LOG_FORMAT=text

# Security (generate via: openssl rand -hex 32)
# min 32 bytes random for prod
SESSION_SECRET=replace-with-random-32-byte-hex

# Optional - SMTP untuk kirim PDF kwitansi via email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
